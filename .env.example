# Neon Postgres connection string (used by Drizzle ORM and drizzle-kit)
# Get it from https://console.neon.tech -> your project -> Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Stack Auth (https://app.stack-auth.com -> your project -> API Keys)
# Read automatically by @stackframe/stack — see stack.tsx
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Cloudinary (https://console.cloudinary.com -> Dashboard)
# Used by next-cloudinary's CldImage to render poster/review images
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
